{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PreeceMeet",
  "version": "0.6.5",
  "identifier": "com.russellpreece.preecemeet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PreeceMeet",
        "width": 1200,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "RWRO38zXcBNhe/hAACh6cfA+apYLXav/yBTsGYVzl2k4nRbziImiE4Aw",
      "endpoints": [
        "https://raw.githubusercontent.com/sp1z/PreeceMeet/main/PreeceMeet.Tauri/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
