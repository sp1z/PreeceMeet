<UserControl x:Class="PreeceMeet.Controls.VideoGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#0f0f1a">
    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
        <!-- The UniformGrid column count is set in code-behind based on participant count -->
        <UniformGrid x:Name="PART_Grid"
                     Columns="2"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"/>
    </ScrollViewer>
</UserControl>
