<Window x:Class="PreeceMeet.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PreeceMeet.Controls"
        Title="PreeceMeet"
        MinWidth="720" MinHeight="500"
        Background="#0f0f1a"
        Foreground="White"
        Closing="Window_Closing">
    <Window.Resources>
        <!-- Icon button style (toolbar) -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3a5c"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#1e1e30"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="JoinButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#4f46e5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338ca"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HangupButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#dc2626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b91c1c"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top toolbar -->
            <RowDefinition Height="52"/>
            <!-- Video area -->
            <RowDefinition Height="*"/>
            <!-- Bottom bar -->
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- ── Top toolbar ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#12122a" Padding="12,0">
            <DockPanel VerticalAlignment="Center">
                <!-- App name -->
                <TextBlock Text="PreeceMeet"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#7c6fe0"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           Margin="0,0,16,0"/>

                <!-- Settings gear (far right) -->
                <Button x:Name="BtnSettings"
                        Content="⚙"
                        Style="{StaticResource ToolbarButton}"
                        ToolTip="Settings"
                        DockPanel.Dock="Right"
                        Margin="6,0,0,0"
                        Click="BtnSettings_Click"/>

                <!-- Disconnect button (far right, visible only when connected) -->
                <Button x:Name="BtnDisconnect"
                        Content="Disconnect"
                        Style="{StaticResource ToolbarButton}"
                        Background="#7f1d1d"
                        ToolTip="Leave the current room"
                        DockPanel.Dock="Right"
                        Margin="6,0,0,0"
                        Visibility="Collapsed"
                        Click="BtnDisconnect_Click"/>

                <!-- Room name + Join -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="TxtRoomName"
                             Width="260"
                             Background="#1e1e30"
                             Foreground="White"
                             BorderBrush="#3a3a5c"
                             BorderThickness="1"
                             Padding="8,6"
                             FontSize="13"
                             CaretBrush="White"
                             VerticalContentAlignment="Center"
                             KeyDown="TxtRoomName_KeyDown">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="5">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button x:Name="BtnJoin"
                            Content="Join"
                            Style="{StaticResource JoinButton}"
                            Margin="8,0,0,0"
                            Click="BtnJoin_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Video grid ──────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#0f0f1a">
            <Grid>
                <!-- Empty state shown before joining -->
                <StackPanel x:Name="PnlEmptyState"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="No active call"
                               FontSize="22"
                               Foreground="#3a3a5c"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter a room name above and press Join."
                               FontSize="14"
                               Foreground="#2d2d44"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Live video grid -->
                <controls:VideoGridControl x:Name="VideoGrid" Visibility="Collapsed"/>

                <!-- Status overlay (connecting…) -->
                <Border x:Name="PnlStatus"
                        Background="#CC0f0f1a"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtStatus"
                                   Text="Connecting…"
                                   FontSize="20"
                                   Foreground="#7c6fe0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatusSub"
                                   Text=""
                                   FontSize="13"
                                   Foreground="#666"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Bottom control bar ─────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#12122a">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding ElementName=BtnDisconnect, Path=IsVisible}">
                <Button x:Name="BtnToggleMic"
                        Content="🎤 Mute"
                        Style="{StaticResource ToolbarButton}"
                        ToolTip="Toggle microphone"
                        Margin="0,0,10,0"
                        Click="BtnToggleMic_Click"/>
                <Button x:Name="BtnToggleCam"
                        Content="📹 Stop Video"
                        Style="{StaticResource ToolbarButton}"
                        ToolTip="Toggle camera"
                        Margin="0,0,10,0"
                        Click="BtnToggleCam_Click"/>
                <Button x:Name="BtnHangup"
                        Content="📞 Hang Up"
                        Style="{StaticResource HangupButton}"
                        ToolTip="Leave call"
                        Click="BtnHangup_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
