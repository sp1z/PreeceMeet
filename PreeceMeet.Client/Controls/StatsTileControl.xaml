<UserControl x:Class="PreeceMeet.Controls.StatsTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="5">
    <Border CornerRadius="8" Background="#1a1a2e" ClipToBounds="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="14,12">
            <StackPanel>
                <TextBlock Text="📊 Debug Stats" FontSize="13" FontWeight="SemiBold"
                           Foreground="White" Margin="0,0,0,10"/>

                <TextBlock x:Name="TxtConnState"   FontSize="11" Foreground="#a0a0c0" Margin="0,2"/>
                <TextBlock x:Name="TxtPing"        FontSize="11" Foreground="#a0a0c0" Margin="0,2"/>
                <TextBlock x:Name="TxtConnected"   FontSize="11" Foreground="#a0a0c0" Margin="0,2"/>
                <TextBlock x:Name="TxtParticipants" FontSize="11" Foreground="#a0a0c0" Margin="0,2"/>

                <Border Height="1" Background="#2a2b3d" Margin="0,10,0,6"/>

                <TextBlock Text="PARTICIPANTS" FontSize="10" FontWeight="SemiBold"
                           Foreground="#555577" Margin="0,0,0,6"/>
                <ItemsControl x:Name="ParticipantList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="11"
                                       Foreground="#9a9bc0" Margin="0,2" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="1" Background="#2a2b3d" Margin="0,10,0,6"/>

                <TextBlock x:Name="TxtUpdated" FontSize="10" Foreground="#44445a"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
