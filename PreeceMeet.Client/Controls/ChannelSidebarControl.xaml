<UserControl x:Class="PreeceMeet.Controls.ChannelSidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SidebarBg}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" BorderBrush="#2a2b3d" BorderThickness="0,0,0,1" Padding="12,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="PreeceMeet" FontWeight="Bold" FontSize="15"
                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                <Button x:Name="BtnAddChannel" DockPanel.Dock="Right"
                        Content="&#xE710;"
                        FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                        Padding="4" ToolTip="Add channel"
                        Click="BtnAddChannel_Click"/>
            </DockPanel>
        </Border>

        <!-- ── Section label ───────────────────────────────────────────────── -->
        <TextBlock Grid.Row="1" Text="CHANNELS" FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource TextMuted}" Margin="14,12,12,4"
                   LetterSpacing="1"/>

        <!-- ── Channel list ────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="ChannelList" Margin="6,2,6,2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="RowBorder"
                                CornerRadius="6" Margin="0,1" Padding="10,8"
                                Cursor="Hand"
                                MouseLeftButtonDown="Channel_Click"
                                MouseRightButtonDown="Channel_RightClick"
                                Background="Transparent"
                                MinHeight="44">
                            <Border.ContextMenu>
                                <ContextMenu Tag="{Binding}">
                                    <MenuItem Header="Edit channel" Tag="{Binding}"
                                              Click="MenuChannelEdit_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Delete channel" Tag="{Binding}"
                                              Click="MenuChannelDelete_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>   <!-- emoji -->
                                    <ColumnDefinition Width="*"/>      <!-- name + participants -->
                                    <ColumnDefinition Width="Auto"/>   <!-- badge -->
                                </Grid.ColumnDefinitions>

                                <!-- Colour emoji / icon -->
                                <Border Grid.Column="0" Width="34" Height="34"
                                        CornerRadius="8" Background="#2a2b3d"
                                        Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ChannelIcon}"
                                               FontFamily="Segoe UI Emoji, Segoe UI"
                                               FontSize="17"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name + participant summary -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <DockPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Activity dot -->
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{StaticResource OnlineDot}"
                                                 Margin="6,0,0,0" VerticalAlignment="Center"
                                                 Visibility="{Binding HasActivity, Converter={StaticResource BoolToVis}}"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding ParticipantSummary}"
                                               FontSize="12" Foreground="{StaticResource TextMuted}"
                                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding ShowParticipants, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <!-- Participant count badge -->
                                <Border Grid.Column="2" CornerRadius="10"
                                        Background="#3a3a5c" Padding="7,2"
                                        VerticalAlignment="Center" Margin="6,0,0,0"
                                        Visibility="{Binding ShowCount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ParticipantCount}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#c0c0e0"/>
                                </Border>
                            </Grid>

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsJoined}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarHover}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── User footer ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#17182a" Padding="10,0"
                Cursor="Hand" MouseLeftButtonDown="Footer_Click"
                ToolTip="Account options">
            <Border.ContextMenu>
                <ContextMenu x:Name="FooterMenu">
                    <MenuItem x:Name="MenuSettings" Header="Settings" Click="MenuSettings_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="MenuSignOut" Header="Sign Out" Click="MenuSignOut_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </Border.ContextMenu>

            <DockPanel VerticalAlignment="Center">
                <Border Width="34" Height="34" CornerRadius="17"
                        Background="{StaticResource AccentBlue}"
                        DockPanel.Dock="Left" Margin="0,0,10,0">
                    <TextBlock x:Name="TxtAvatarInitial" Text="?" FontSize="15" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="TxtUserEmail" Text="" FontSize="12"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                           Foreground="{StaticResource TextMuted}"
                           DockPanel.Dock="Right" VerticalAlignment="Center"
                           HorizontalAlignment="Right">
                    <TextBlock.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
