<UserControl x:Class="PreeceMeet.Controls.ChannelSidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SidebarBg}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="48"/>
            <!-- Section label -->
            <RowDefinition Height="Auto"/>
            <!-- Channel list -->
            <RowDefinition Height="*"/>
            <!-- User footer -->
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" BorderBrush="#2a2b3d" BorderThickness="0,0,0,1" Padding="12,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="PreeceMeet" FontWeight="Bold" FontSize="14"
                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                <Button x:Name="BtnAddChannel" DockPanel.Dock="Right"
                        Content="&#xE710;"
                        FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                        Padding="4" ToolTip="Add channel"
                        Click="BtnAddChannel_Click"/>
            </DockPanel>
        </Border>

        <!-- ── Section label ───────────────────────────────────────────────── -->
        <TextBlock Grid.Row="1" Text="CHANNELS" FontSize="10" FontWeight="SemiBold"
                   Foreground="{StaticResource TextMuted}" Margin="12,12,12,4"/>

        <!-- ── Channel list ────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="ChannelList" Margin="0,2,0,2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Each channel row -->
                        <Border x:Name="RowBorder"
                                CornerRadius="4" Margin="6,1" Padding="8,6"
                                Cursor="Hand"
                                MouseLeftButtonDown="Channel_Click"
                                Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <!-- Channel name row with activity dot -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Hash icon -->
                                        <TextBlock Text="#" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Activity dot -->
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource OnlineDot}"
                                                 Margin="6,0,0,0" VerticalAlignment="Center"
                                                 Visibility="{Binding HasActivity, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>

                                    <!-- Participant names (shown when count > 0) -->
                                    <TextBlock Text="{Binding ParticipantSummary}" FontSize="10"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="17,2,0,0" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding ShowParticipants, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <!-- Participant count badge -->
                                <Border Grid.Column="1" CornerRadius="8"
                                        Background="#2a2b3d" Padding="5,1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding ShowCount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ParticipantCount}" FontSize="10"
                                               Foreground="{StaticResource TextMuted}"/>
                                </Border>
                            </Grid>

                            <!-- Hover/active triggers -->
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsJoined}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarHover}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── User footer ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#17182a" Padding="10,0"
                Cursor="Hand" MouseLeftButtonDown="Footer_Click"
                ToolTip="Account options">
            <Border.ContextMenu>
                <ContextMenu x:Name="FooterMenu">
                    <MenuItem x:Name="MenuSettings" Header="Settings" Click="MenuSettings_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="MenuSignOut" Header="Sign Out" Click="MenuSignOut_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </Border.ContextMenu>

            <DockPanel VerticalAlignment="Center">
                <!-- Avatar circle -->
                <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource AccentBlue}"
                        DockPanel.Dock="Left" Margin="0,0,8,0">
                    <TextBlock x:Name="TxtAvatarInitial" Text="?" FontSize="14" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Email truncated -->
                <TextBlock x:Name="TxtUserEmail" Text="" FontSize="11"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <!-- Chevron hint -->
                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                           Foreground="{StaticResource TextMuted}"
                           DockPanel.Dock="Right" VerticalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Right">
                    <TextBlock.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
