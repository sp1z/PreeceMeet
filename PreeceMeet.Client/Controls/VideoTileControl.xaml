<UserControl x:Class="PreeceMeet.Controls.VideoTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="270" d:DesignWidth="480"
             Margin="5"
             AllowDrop="True"
             MouseLeftButtonDown="OnMouseLeftButtonDown"
             MouseMove="OnMouseMove"
             DragOver="OnDragOver"
             Drop="OnDrop">

    <Grid>
        <!-- Clipped video content -->
        <Border CornerRadius="8" ClipToBounds="True" Background="#1a1a2e">
            <Grid>
                <Image x:Name="PART_VideoImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed"/>

                <Grid x:Name="PART_AvatarOverlay" Visibility="Visible">
                    <Ellipse Width="72" Height="72"
                             Fill="#2d2d44"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="PART_AvatarInitial"
                               Text="?"
                               FontSize="30"
                               Foreground="#a0a0c0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Name + mute badge -->
                <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Margin="8" Padding="6,3"
                        Background="#AA000000" CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="PART_MutedIcon"
                                   Text="&#xE74F;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="#FF5252"
                                   Margin="0,0,5,0"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PART_NameLabel"
                                   Text="Participant"
                                   Foreground="White"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Speaking ring — rendered on top, not clipped -->
        <Border x:Name="PART_SpeakingRing"
                CornerRadius="8"
                BorderThickness="2.5"
                BorderBrush="#00C853"
                Background="Transparent"
                IsHitTestVisible="False"
                Visibility="Collapsed"/>

        <!-- Drag-over indicator -->
        <Border x:Name="PART_DropIndicator"
                CornerRadius="8"
                BorderThickness="2"
                BorderBrush="#60FFFFFF"
                Background="#20FFFFFF"
                IsHitTestVisible="False"
                Visibility="Collapsed"/>
    </Grid>

    <UserControl.ContextMenu>
        <ContextMenu x:Name="PART_ContextMenu">
            <MenuItem x:Name="MenuMuteLocally" Header="Mute for me"
                      Click="MenuMuteLocally_Click"/>
            <Separator x:Name="MenuSeparator"/>
            <MenuItem Header="Pin to top" Click="MenuPinToTop_Click"/>
        </ContextMenu>
    </UserControl.ContextMenu>
</UserControl>
