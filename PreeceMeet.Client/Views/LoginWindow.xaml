<Window x:Class="PreeceMeet.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PreeceMeet — Sign In"
        Width="360" Height="310"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PreeceMeet" FontSize="20" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Label Grid.Row="1" Content="Email address" Padding="0,0,0,2"/>
        <TextBox Grid.Row="2" x:Name="TxtEmail" Margin="0,0,0,12"
                 KeyDown="Input_KeyDown"/>

        <Label Grid.Row="3" Content="Password" Padding="0,0,0,2"/>
        <PasswordBox Grid.Row="4" x:Name="TxtPassword" Margin="0,0,0,8"
                     KeyDown="Input_KeyDown"/>

        <CheckBox Grid.Row="5" x:Name="ChkRemember" Content="Remember my email"
                  Margin="0,0,0,8"/>

        <TextBlock Grid.Row="6" x:Name="TxtError" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Button Grid.Row="7" x:Name="BtnLogin" Content="Sign In" IsDefault="True"
                HorizontalAlignment="Stretch" Padding="0,6"
                Click="BtnLogin_Click"/>
    </Grid>
</Window>
