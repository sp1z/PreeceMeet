<Window x:Class="PreeceMeet.Views.AddChannelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Channel"
        Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1b2e" FontFamily="Segoe UI">

    <StackPanel Margin="20">
        <TextBlock Text="Channel name (room name)" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtName" FontSize="14" Margin="0,0,0,12"
                 Background="#2a2b3d" Foreground="White" CaretBrush="White"
                 BorderBrush="#3a3a5c" BorderThickness="1"
                 KeyDown="Txt_KeyDown"/>

        <TextBlock Text="Display name (optional)" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtDisplay" FontSize="14" Margin="0,0,0,16"
                 Background="#2a2b3d" Foreground="White" CaretBrush="White"
                 BorderBrush="#3a3a5c" BorderThickness="1"
                 KeyDown="Txt_KeyDown"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="Add" Width="80"
                    Background="{StaticResource AccentBlue}"
                    Click="BtnAdd_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
