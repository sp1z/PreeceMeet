<Window x:Class="PreeceMeet.Views.AddChannelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Channel"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1b2e" FontFamily="Segoe UI">

    <StackPanel Margin="20">
        <TextBlock Text="Emoji icon" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
        <!-- Quick picks -->
        <WrapPanel Margin="0,0,0,6">
            <Button Content="💬" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Chat"/>
            <Button Content="🎮" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Gaming"/>
            <Button Content="🎵" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Music"/>
            <Button Content="📢" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Announce"/>
            <Button Content="🎉" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Party"/>
            <Button Content="💼" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Work"/>
            <Button Content="🔒" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Private"/>
            <Button Content="🌍" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Global"/>
            <Button Content="🤖" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Bot"/>
            <Button Content="🎙️" FontSize="18" Background="Transparent" Padding="4,2" Margin="2"
                    Click="EmojiPick_Click" ToolTip="Voice"/>
        </WrapPanel>
        <TextBox x:Name="TxtEmoji" FontSize="18" MaxLength="4" Width="60"
                 HorizontalAlignment="Left"
                 Background="#2a2b3d" Foreground="White" CaretBrush="White"
                 BorderBrush="#3a3a5c" BorderThickness="1"
                 Margin="0,0,0,14"/>

        <TextBlock Text="Room name (used to join)" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtName" FontSize="14" Margin="0,0,0,12"
                 Background="#2a2b3d" Foreground="White" CaretBrush="White"
                 BorderBrush="#3a3a5c" BorderThickness="1"
                 KeyDown="Txt_KeyDown"/>

        <TextBlock Text="Display name" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtDisplay" FontSize="14" Margin="0,0,0,16"
                 Background="#2a2b3d" Foreground="White" CaretBrush="White"
                 BorderBrush="#3a3a5c" BorderThickness="1"
                 KeyDown="Txt_KeyDown"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="Save" Width="80"
                    Background="{StaticResource AccentBlue}"
                    Click="BtnAdd_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
