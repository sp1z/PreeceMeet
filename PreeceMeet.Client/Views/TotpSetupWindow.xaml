<Window x:Class="PreeceMeet.Views.TotpSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PreeceMeet — Set Up Two-Factor Authentication"
        Width="400" Height="540"
        MinHeight="480" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Set Up Authenticator"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Text="Scan the QR code below with Microsoft Authenticator, Google Authenticator, or any TOTP app. Then enter the 6-digit code to confirm."
                   FontSize="12" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,16"/>

        <!-- QR code image -->
        <Border Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,12"
                BorderBrush="Gray" BorderThickness="1">
            <Image x:Name="ImgQr" Width="180" Height="180" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Border>

        <!-- Manual entry fallback -->
        <Expander Grid.Row="3" Header="Can't scan? Enter code manually" Margin="0,0,0,16">
            <StackPanel Margin="0,8,0,0">
                <TextBlock Text="Enter this key into your authenticator app:" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtSecret" IsReadOnly="True" FontFamily="Consolas"
                         FontSize="13" TextWrapping="Wrap" Margin="0,0,0,4"/>
            </StackPanel>
        </Expander>

        <Label Grid.Row="4" Content="Confirmation code" Padding="0,0,0,2"/>
        <TextBox Grid.Row="5" x:Name="TxtCode" MaxLength="6" FontSize="20"
                 TextAlignment="Center" Margin="0,0,0,8"
                 KeyDown="TxtCode_KeyDown" TextChanged="TxtCode_TextChanged"/>

        <TextBlock Grid.Row="6" x:Name="TxtError" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Button Grid.Row="7" x:Name="BtnVerify" Content="Confirm and Sign In" IsDefault="True"
                HorizontalAlignment="Stretch" Padding="0,6"
                Click="BtnVerify_Click"/>
    </Grid>
</Window>
