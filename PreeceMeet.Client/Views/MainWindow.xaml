<Window x:Class="PreeceMeet.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PreeceMeet.Controls"
        Title="PreeceMeet"
        MinWidth="200"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" IsLocked="True">
            <ToolBar>
                <TextBlock Text="PreeceMeet" FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <Separator/>
                <TextBox x:Name="TxtRoomName" Width="240" VerticalContentAlignment="Center"
                         ToolTip="Room name" KeyDown="TxtRoomName_KeyDown"/>
                <Button x:Name="BtnJoin" Content="Join" Margin="4,0,0,0"
                        Background="{StaticResource AccentBlue}"
                        ToolTip="Join the room" Click="BtnJoin_Click"/>
                <!-- BtnDisconnect kept for IsVisible binding on call controls panel -->
                <Button x:Name="BtnDisconnect" Visibility="Collapsed"/>
                <Separator/>
                <Button x:Name="BtnLayoutToggle" Content="≡" FontSize="16"
                        Background="Transparent" Foreground="#DDD"
                        ToolTip="Switch to strip layout" Click="BtnLayoutToggle_Click"/>
                <Button x:Name="BtnSettings" Content="⚙" FontSize="16"
                        Background="Transparent" Foreground="#DDD"
                        ToolTip="Settings" Click="BtnSettings_Click"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Video area -->
        <Border Grid.Row="1" Background="Black">
            <Grid>
                <StackPanel x:Name="PnlEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No active call" FontSize="20" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter a room name above and press Join."
                               FontSize="13" Foreground="#444"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <controls:VideoGridControl x:Name="VideoGrid" Visibility="Collapsed"/>

                <Border x:Name="PnlStatus" Background="#CC000000" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtStatus" Text="Connecting..." FontSize="20"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatusSub" Text="" FontSize="13"
                                   Foreground="#aaa" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Call controls -->
        <Border Grid.Row="2" Background="#12121e" Padding="0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Circle call buttons — centred -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsEnabled="{Binding ElementName=BtnDisconnect, Path=IsVisible}">
                    <Button x:Name="BtnToggleMic"
                            Style="{StaticResource CircleButton}"
                            Content="&#xE720;"
                            ToolTip="Mute microphone"
                            Click="BtnToggleMic_Click"
                            Margin="0,0,16,0"/>
                    <Button x:Name="BtnToggleCam"
                            Style="{StaticResource CircleButton}"
                            Content="&#xE722;"
                            ToolTip="Stop camera"
                            Click="BtnToggleCam_Click"
                            Margin="0,0,16,0"/>
                    <Button x:Name="BtnHangup"
                            Style="{StaticResource CircleButton}"
                            Background="{StaticResource DangerRed}"
                            Content="&#xE778;"
                            ToolTip="Leave call"
                            Click="BtnHangup_Click"/>
                </StackPanel>

                <!-- Update status — right-aligned -->
                <TextBlock Grid.Column="1"
                           x:Name="TxtUpdateStatus" Text=""
                           Foreground="#666" FontSize="11"
                           Margin="0,0,12,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
