<Window x:Class="PreeceMeet.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PreeceMeet.Controls"
        Title="PreeceMeet v?"
        MinWidth="200"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="RowTop"      Height="Auto"/>
            <RowDefinition                       Height="*"/>
            <RowDefinition x:Name="RowControls" Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Top bar ──────────────────────────────────────────────────────── -->
        <Border x:Name="PnlTopBar" Grid.Row="0" Background="#12121e" Padding="8,5">
            <DockPanel>
                <!-- App name -->
                <TextBlock Text="PreeceMeet" FontWeight="SemiBold" Foreground="#ccc"
                           FontSize="13" VerticalAlignment="Center"
                           Margin="0,0,12,0" DockPanel.Dock="Left"/>

                <!-- Right-side utility buttons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnHideUI"
                            Content="&#xE70D;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Hide toolbars (click top edge to restore)"
                            Margin="0,0,4,0" Click="BtnHideUI_Click"/>
                    <Button x:Name="BtnFullscreen"
                            Content="&#xE740;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Full screen (F11)"
                            Margin="0,0,4,0" Click="BtnFullscreen_Click"/>
                    <Button x:Name="BtnLayoutToggle"
                            Content="&#xE8A9;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Switch to strip layout"
                            Margin="0,0,4,0" Click="BtnLayoutToggle_Click"/>
                    <Button x:Name="BtnAdmin" Content="Admin" FontSize="11"
                            Background="Transparent" Foreground="#888"
                            Visibility="Collapsed"
                            ToolTip="User management"
                            Margin="0,0,4,0" Click="BtnAdmin_Click"/>
                    <Button x:Name="BtnSettings"
                            Content="&#xE713;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Settings" Click="BtnSettings_Click"/>
                </StackPanel>

                <!-- Room name + join (centre fills remaining space) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="TxtRoomName" Width="200" VerticalContentAlignment="Center"
                             ToolTip="Room name" KeyDown="TxtRoomName_KeyDown"/>
                    <Button x:Name="BtnJoin" Content="Join" Margin="6,0,0,0"
                            Background="{StaticResource AccentBlue}"
                            ToolTip="Join the room" Click="BtnJoin_Click"/>
                    <!-- Hidden flag for call-controls enabled binding -->
                    <Button x:Name="BtnDisconnect" Visibility="Collapsed"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Video area ────────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="Black">
            <Grid>
                <StackPanel x:Name="PnlEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No active call" FontSize="20" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter a room name above and press Join."
                               FontSize="13" Foreground="#444"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <controls:VideoGridControl x:Name="VideoGrid" Visibility="Collapsed"/>

                <Border x:Name="PnlStatus" Background="#CC000000" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtStatus" Text="Connecting..." FontSize="20"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatusSub" Text="" FontSize="13"
                                   Foreground="#aaa" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Call controls ─────────────────────────────────────────────────── -->
        <Border x:Name="PnlCallControls" Grid.Row="2" Background="#12121e" Padding="0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsEnabled="{Binding ElementName=BtnDisconnect, Path=IsVisible}">
                    <Button x:Name="BtnToggleMic"
                            Style="{StaticResource CircleButton}"
                            Content="&#xE720;"
                            ToolTip="Mute microphone"
                            Click="BtnToggleMic_Click"
                            Margin="0,0,16,0"/>
                    <Button x:Name="BtnToggleCam"
                            Style="{StaticResource CircleButton}"
                            Content="&#xE722;"
                            ToolTip="Stop camera"
                            Click="BtnToggleCam_Click"
                            Margin="0,0,16,0"/>
                    <Button x:Name="BtnHangup"
                            Style="{StaticResource CircleButton}"
                            Background="{StaticResource DangerRed}"
                            Content="&#xE778;"
                            ToolTip="Leave call"
                            Click="BtnHangup_Click"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           x:Name="TxtUpdateStatus" Text=""
                           Foreground="#666" FontSize="11"
                           Margin="0,0,12,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Reveal strip (shown when toolbars hidden, click to restore) ───── -->
        <Border x:Name="PnlRevealBar"
                Grid.Row="0" Grid.RowSpan="3"
                VerticalAlignment="Top" Height="6"
                Background="#40FFFFFF"
                Cursor="Hand"
                Visibility="Collapsed"
                IsHitTestVisible="True"
                MouseLeftButtonDown="PnlRevealBar_Click"
                ToolTip="Click to restore toolbars"/>
    </Grid>
</Window>
