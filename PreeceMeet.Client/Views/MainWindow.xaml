<Window x:Class="PreeceMeet.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PreeceMeet.Controls"
        Title="PreeceMeet v?"
        MinWidth="300"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Background="#1a1b2e"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- top bar -->
            <RowDefinition Height="*"/>     <!-- content -->
            <RowDefinition Height="Auto"/>  <!-- call controls -->
        </Grid.RowDefinitions>

        <!-- ── Top bar ──────────────────────────────────────────────────────── -->
        <Border x:Name="PnlTopBar" Grid.Row="0" Background="#12121e" Padding="8,5">
            <DockPanel>
                <!-- Hamburger to toggle sidebar -->
                <Button x:Name="BtnToggleSidebar"
                        Content="&#xE700;"
                        FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Background="Transparent" Foreground="#888"
                        DockPanel.Dock="Left"
                        ToolTip="Toggle sidebar"
                        Margin="0,0,8,0" Click="BtnToggleSidebar_Click"/>

                <!-- Current room name -->
                <TextBlock x:Name="TxtCurrentRoom" Text="No active call"
                           FontSize="13" FontWeight="SemiBold" Foreground="#ccc"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>

                <!-- Right-side utility buttons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnHideUI"
                            Content="&#xE70D;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Hide toolbars (click top edge to restore)"
                            Margin="0,0,4,0" Click="BtnHideUI_Click"/>
                    <Button x:Name="BtnFullscreen"
                            Content="&#xE740;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Full screen (F11)"
                            Margin="0,0,4,0" Click="BtnFullscreen_Click"/>
                    <Button x:Name="BtnLayoutToggle"
                            Content="&#xE8A9;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Game Mode"
                            Margin="0,0,4,0" Click="BtnLayoutToggle_Click"/>
                    <Button x:Name="BtnStats"
                            Content="&#xE9F9;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Show debug stats panel"
                            Margin="0,0,4,0" Click="BtnStats_Click"/>
                    <Button x:Name="BtnAdmin" Content="Admin" FontSize="11"
                            Background="Transparent" Foreground="#888"
                            Visibility="Collapsed"
                            ToolTip="User management"
                            Margin="0,0,4,0" Click="BtnAdmin_Click"/>
                    <Button x:Name="BtnSettings"
                            Content="&#xE713;"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            ToolTip="Settings" Click="BtnSettings_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Content: sidebar + video ─────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColSidebar" Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ────────────────────────────────────────────────── -->
            <controls:ChannelSidebarControl x:Name="Sidebar" Grid.Column="0"/>

            <!-- ── Video area ─────────────────────────────────────────────── -->
            <Border Grid.Column="1" Background="#0d0d1a">
                <Grid>
                    <StackPanel x:Name="PnlEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE717;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="#2a2b3d" HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="Select a channel to join" FontSize="20"
                                   Foreground="#72748c" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Click a channel in the sidebar to start a call"
                                   FontSize="13" Foreground="#3a3a5c"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <controls:VideoGridControl x:Name="VideoGrid" Visibility="Collapsed"/>

                    <!-- Professional status overlay with spinner -->
                    <Border x:Name="PnlStatus" Background="#E6080816" Visibility="Collapsed">
                        <Border Background="#1a1b2e" CornerRadius="16" Padding="40,32"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="400"
                                Effect="{StaticResource CardShadow}">
                            <StackPanel HorizontalAlignment="Center">
                                <!-- Spinning ring -->
                                <Grid Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,20">
                                    <Ellipse Width="48" Height="48"
                                             Stroke="#2a2b3d" StrokeThickness="4"/>
                                    <Ellipse x:Name="SpinnerArc" Width="48" Height="48"
                                             Stroke="{StaticResource AccentBlue}" StrokeThickness="4"
                                             StrokeDashArray="2.5 5"
                                             StrokeDashCap="Round"
                                             RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform x:Name="SpinnerRotation" Angle="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>

                                <TextBlock x:Name="TxtStatus" Text="Connecting..."
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#e3e5e8"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="TxtStatusSub" Text=""
                                           FontSize="13" Foreground="#72748c"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,8,0,0"/>

                                <!-- Step indicators -->
                                <StackPanel x:Name="PnlStatusSteps" Margin="0,16,0,0"
                                            HorizontalAlignment="Center"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="TxtStep1" Text="●  Authenticating"
                                               FontSize="12" Foreground="#555" Margin="0,3"/>
                                    <TextBlock x:Name="TxtStep2" Text="○  Starting devices"
                                               FontSize="12" Foreground="#555" Margin="0,3"/>
                                    <TextBlock x:Name="TxtStep3" Text="○  Joining room"
                                               FontSize="12" Foreground="#555" Margin="0,3"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Update overlay -->
                    <Border x:Name="PnlUpdateOverlay" Background="#E6080816" Visibility="Collapsed">
                        <Border Background="#1a1b2e" CornerRadius="16" Padding="40,32"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="420"
                                Effect="{StaticResource CardShadow}">
                            <StackPanel HorizontalAlignment="Center">
                                <!-- Update icon -->
                                <TextBlock Text="&#xE895;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="36"
                                           Foreground="{StaticResource AccentBlue}"
                                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

                                <TextBlock x:Name="TxtUpdateTitle" Text="Updating PreeceMeet"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#e3e5e8"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtUpdateDetail" Text=""
                                           FontSize="13" Foreground="#72748c"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,16"/>

                                <!-- Progress bar -->
                                <Grid Height="6" Margin="0,0,0,8">
                                    <Border Background="#2a2b3d" CornerRadius="3"/>
                                    <Border x:Name="UpdateProgressFill"
                                            Background="{StaticResource AccentBlue}"
                                            CornerRadius="3"
                                            RenderTransformOrigin="0,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="ProgressScale" ScaleX="0"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                                <TextBlock x:Name="TxtUpdatePercent" Text="0%"
                                           FontSize="11" Foreground="#555"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Call controls ─────────────────────────────────────────────────── -->
        <Border x:Name="PnlCallControls" Grid.Row="2" Background="#12121e" Padding="0,8">
            <Grid>
                <!-- Buttons always centred, update text floats over the right edge -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="BtnToggleMic"
                            Style="{StaticResource CircleButton}"
                            Content="&#xE720;"
                            ToolTip="Mute microphone (Ctrl+M)"
                            Click="BtnToggleMic_Click"
                            Margin="0,0,16,0"/>
                    <Button x:Name="BtnToggleCam"
                            Style="{StaticResource CircleButton}"
                            Content="&#xE722;"
                            ToolTip="Stop camera (Ctrl+E)"
                            Click="BtnToggleCam_Click"
                            Margin="0,0,16,0"/>
                    <Button x:Name="BtnHangup"
                            Style="{StaticResource CircleButton}"
                            Background="{StaticResource DangerRed}"
                            Content="&#xE778;"
                            ToolTip="Leave call (Ctrl+D)"
                            Click="BtnHangup_Click"
                            IsEnabled="False"/>
                </StackPanel>

                <!-- Update status floats right — no effect on button layout -->
                <TextBlock x:Name="TxtUpdateStatus" Text=""
                           Foreground="#666" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- ── Reveal strip (shown when toolbars hidden) ────────────────────── -->
        <Border x:Name="PnlRevealBar"
                Grid.Row="0" Grid.RowSpan="3"
                VerticalAlignment="Top" Height="28"
                Background="#CC12121e"
                Cursor="Hand"
                Visibility="Collapsed"
                IsHitTestVisible="True"
                MouseLeftButtonDown="PnlRevealBar_Click">
            <TextBlock Text="&#xE70E;  Click to restore toolbar"
                       FontFamily="Segoe MDL2 Assets, Segoe UI" FontSize="11"
                       Foreground="#aaa"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Hidden sentinel used by call-controls IsEnabled binding -->
        <Button x:Name="BtnDisconnect" Visibility="Collapsed" Grid.Row="0"/>
    </Grid>
</Window>
