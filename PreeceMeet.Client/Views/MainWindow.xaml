<Window x:Class="PreeceMeet.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PreeceMeet.Controls"
        Title="PreeceMeet"
        MinWidth="720" MinHeight="500"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" IsLocked="True">
            <ToolBar>
                <TextBlock Text="PreeceMeet" FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <Separator/>
                <TextBox x:Name="TxtRoomName" Width="240" VerticalContentAlignment="Center"
                         ToolTip="Room name" KeyDown="TxtRoomName_KeyDown"/>
                <Button x:Name="BtnJoin" Content="Join" Margin="4,0,0,0"
                        ToolTip="Join the room" Click="BtnJoin_Click"/>
                <Separator/>
                <Button x:Name="BtnDisconnect" Content="Disconnect" Visibility="Collapsed"
                        ToolTip="Leave the current room" Click="BtnDisconnect_Click"/>
                <Button x:Name="BtnSettings" Content="Settings" Margin="4,0,0,0"
                        ToolTip="Settings" Click="BtnSettings_Click"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Video area -->
        <Border Grid.Row="1" Background="Black">
            <Grid>
                <StackPanel x:Name="PnlEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No active call" FontSize="20" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter a room name above and press Join."
                               FontSize="13" Foreground="#444"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <controls:VideoGridControl x:Name="VideoGrid" Visibility="Collapsed"/>

                <Border x:Name="PnlStatus" Background="#CC000000" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtStatus" Text="Connecting..." FontSize="20"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatusSub" Text="" FontSize="13"
                                   Foreground="#aaa" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Call controls -->
        <StatusBar Grid.Row="2">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0" HorizontalAlignment="Center" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            IsEnabled="{Binding ElementName=BtnDisconnect, Path=IsVisible}">
                    <Button x:Name="BtnToggleMic" Content="Mic: On" Margin="0,0,8,0"
                            ToolTip="Toggle microphone" Click="BtnToggleMic_Click"/>
                    <Button x:Name="BtnToggleCam" Content="Camera: On" Margin="0,0,8,0"
                            ToolTip="Toggle camera" Click="BtnToggleCam_Click"/>
                    <Button x:Name="BtnHangup" Content="Hang Up" Foreground="White"
                            Background="Firebrick" BorderBrush="DarkRed"
                            ToolTip="Leave call" Click="BtnHangup_Click"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem Grid.Column="1">
                <TextBlock x:Name="TxtUpdateStatus" Text="" Foreground="#888"
                           FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
