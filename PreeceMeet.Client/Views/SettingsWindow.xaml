<Window x:Class="PreeceMeet.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PreeceMeet — Settings"
        Width="460" Height="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Label Content="Display Name" Padding="0,0,0,2"/>
            <TextBox x:Name="TxtDisplayName" Margin="0,0,0,12"/>

            <Label Content="Auth API URL" Padding="0,0,0,2"/>
            <TextBox x:Name="TxtServerUrl" Margin="0,0,0,12"/>

            <Label Content="Default Room Name" Padding="0,0,0,2"/>
            <TextBox x:Name="TxtLastRoom" Margin="0,0,0,12"/>

            <Label Content="Camera Device" Padding="0,0,0,2"/>
            <ComboBox x:Name="CmbCamera" Margin="0,0,0,12"/>

            <Label Content="Microphone Device" Padding="0,0,0,2"/>
            <ComboBox x:Name="CmbMic" Margin="0,0,0,12"/>

            <Label Content="Speaker Device" Padding="0,0,0,2"/>
            <ComboBox x:Name="CmbSpeaker" Margin="0,0,0,12"/>

            <CheckBox x:Name="ChkRemember" Content="Remember email address" Margin="0,0,0,16"/>

            <Button x:Name="BtnSignOut" Content="Sign Out (clear saved session)"
                    HorizontalAlignment="Left" Padding="10,4"
                    Click="BtnSignOut_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" IsCancel="True" Padding="16,5" Margin="0,0,8,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Save" IsDefault="True" Padding="16,5"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
