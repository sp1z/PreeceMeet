<Window x:Class="PreeceMeet.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PreeceMeet — Settings"
        Width="460" Height="580"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Label Content="Display Name" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtDisplayName" Margin="0,0,0,12"/>

                <Label Content="Auth API URL" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtServerUrl" Margin="0,0,0,12"/>

                <Label Content="Camera Device" Padding="0,0,0,2"/>
                <ComboBox x:Name="CmbCamera" Margin="0,0,0,12"/>

                <Label Content="Microphone Device" Padding="0,0,0,2"/>
                <ComboBox x:Name="CmbMic" Margin="0,0,0,12"/>

                <Label Content="Speaker Device" Padding="0,0,0,2"/>
                <ComboBox x:Name="CmbSpeaker" Margin="0,0,0,12"/>

                <Label Content="Game Mode tile height (px)" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtGameModeTileHeight" Margin="0,0,0,16"/>

                <!-- ── Channels ─────────────────────────────────────────── -->
                <Separator Margin="0,0,0,12"/>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Channels" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"/>
                    <Button x:Name="BtnAddChannel" Content="+ Add" DockPanel.Dock="Right"
                            Padding="10,3" FontSize="11"
                            Background="{StaticResource AccentBlue}"
                            Click="BtnAddChannel_Click"/>
                </DockPanel>

                <Label Content="Auto-join on startup" Padding="0,0,0,2"/>
                <ComboBox x:Name="CmbAutoJoin" Margin="0,0,0,12"/>

                <!-- Channel rows -->
                <ItemsControl x:Name="ChannelListControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2a2b3d" CornerRadius="4" Padding="10,7" Margin="0,2">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="&#xE74D;"
                                            FontFamily="Segoe MDL2 Assets" FontSize="13"
                                            Background="Transparent" Foreground="#666"
                                            Padding="6,2" Tag="{Binding}"
                                            ToolTip="Delete channel"
                                            Click="BtnDeleteChannel_Click"/>
                                    <Button DockPanel.Dock="Right" Content="&#xE70F;"
                                            FontFamily="Segoe MDL2 Assets" FontSize="13"
                                            Background="Transparent" Foreground="#888"
                                            Padding="6,2" Tag="{Binding}"
                                            ToolTip="Edit channel"
                                            Click="BtnEditChannel_Click"/>
                                    <TextBlock Text="{Binding Emoji}" FontSize="16"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                   Foreground="#e3e5e8"/>
                                        <TextBlock Text="{Binding Name}" FontSize="10"
                                                   Foreground="#72748c"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="16,5" Margin="0,0,8,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Save" IsDefault="True" Padding="16,5"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
