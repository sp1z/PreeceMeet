<Window x:Class="PreeceMeet.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PreeceMeet — Settings"
        Width="820" Height="560"
        MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="#1a1b2e"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- Dark TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#252638"/>
            <Setter Property="Foreground"      Value="#e3e5e8"/>
            <Setter Property="CaretBrush"      Value="#e3e5e8"/>
            <Setter Property="BorderBrush"     Value="#3a3a5c"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#252638"/>
            <Setter Property="Foreground"      Value="#e3e5e8"/>
            <Setter Property="BorderBrush"     Value="#3a3a5c"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" CornerRadius="4"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Right" Width="26"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  ClickMode="Press" Focusable="False"
                                                  Background="Transparent" BorderThickness="0"
                                                  Foreground="#72748c" OverridesDefaultStyle="True">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <TextBlock Text="▾" FontSize="10"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="#252638" BorderBrush="#3a3a5c" BorderThickness="1"
                                        CornerRadius="4" MaxHeight="220"
                                        Effect="{StaticResource CardShadow}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5a5a9c"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#e3e5e8"/>
                        <Setter Property="Padding"    Value="10,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#3a3a5c"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#3f3f6c"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section heading -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#72748c"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9a9bc0"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Two-column content ──────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="24,20,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: General + Devices -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- General -->
                    <TextBlock Text="GENERAL" Style="{StaticResource SectionHead}"/>

                    <TextBlock Text="Display name" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtDisplayName" Margin="0,0,0,12"/>

                    <TextBlock Text="Server URL" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtServerUrl" Margin="0,0,0,20"/>

                    <!-- Devices -->
                    <TextBlock Text="DEVICES" Style="{StaticResource SectionHead}"/>

                    <TextBlock Text="Camera" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbCamera" Margin="0,0,0,10"/>

                    <TextBlock Text="Microphone" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbMic" Margin="0,0,0,10"/>

                    <TextBlock Text="Speaker" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbSpeaker" Margin="0,0,0,20"/>

                    <!-- Appearance -->
                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHead}"/>

                    <TextBlock Text="Game Mode tile height (px)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtGameModeTileHeight" Width="80"
                             HorizontalAlignment="Left" Margin="0,0,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Right column: Channels -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header + Add button -->
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="CHANNELS" Style="{StaticResource SectionHead}"
                               VerticalAlignment="Center" Margin="0,0,0,0"/>
                    <Button x:Name="BtnAddChannel" Content="+ Add"
                            DockPanel.Dock="Right" Padding="12,4" FontSize="11"
                            Background="{StaticResource AccentBlue}"
                            Click="BtnAddChannel_Click"/>
                </DockPanel>

                <!-- Auto-join -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="Auto-join on startup" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbAutoJoin"/>
                </StackPanel>

                <!-- Channel list -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ChannelListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252638" CornerRadius="6"
                                        Padding="10,8" Margin="0,0,0,4">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Content="&#xE70F;"
                                                    FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                    Background="Transparent" Foreground="#888"
                                                    Padding="6,2" Tag="{Binding}"
                                                    ToolTip="Edit" Click="BtnEditChannel_Click"/>
                                            <Button Content="&#xE74D;"
                                                    FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                    Background="Transparent" Foreground="#664444"
                                                    Padding="6,2" Tag="{Binding}"
                                                    ToolTip="Delete" Click="BtnDeleteChannel_Click"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Emoji}" FontSize="18"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                       Foreground="#e3e5e8"/>
                                            <TextBlock Text="{Binding Name}" FontSize="10"
                                                       Foreground="#72748c"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ── Footer ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#2a2b3d" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Padding="20,6" Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
                <Button Content="Save" IsDefault="True" Padding="20,6"
                        Background="{StaticResource AccentBlue}"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
